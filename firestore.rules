rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidHTMLFile(data) {
      // Allow classical string content (max 800KB chunked for safety)
      let hasContent = data.keys().hasAll(['content', 'createdAt', 'ownerId']) &&
                       data.keys().size() == 3 &&
                       data.content is string && data.content.size() <= 900000;
                       
      // Allow chunked uploads
      let hasChunks = data.keys().hasAll(['numChunks', 'createdAt', 'ownerId']) &&
                      data.keys().size() == 3 &&
                      data.numChunks is number && data.numChunks > 0 && data.numChunks <= 10; // Up to ~8MB
                      
      return (hasContent || hasChunks) &&
             data.createdAt is number && data.createdAt > 0 &&
             data.ownerId == request.auth.uid;
    }

    match /htmlFiles/{fileId} {
      // Allow public get
      allow get: if isValidId(fileId);
      
      // Allow anyone to query their own files
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      // Allow creation
      allow create: if isSignedIn() &&
                    isValidId(fileId) && 
                    isValidHTMLFile(incoming());
                    
      // Allow deletion only by owner
      allow delete: if isSignedIn() && 
                    isValidId(fileId) && 
                    existing().ownerId == request.auth.uid;
                    
      // Disallow updates
      allow update: if false; 
      
      match /chunks/{chunkId} {
        allow get: if isValidId(fileId) && isValidId(chunkId);
        allow list: if false; // No need to list chunks directly from client
        
        // We use getAfter to ensure the main file is created in the same batch with correct owner
        allow create: if isSignedIn() &&
                      isValidId(chunkId) &&
                      incoming().keys().hasAll(['content']) &&
                      incoming().keys().size() == 1 &&
                      incoming().content is string && incoming().content.size() <= 900000 &&
                      getAfter(/databases/$(database)/documents/htmlFiles/$(fileId)).data.ownerId == request.auth.uid;
                      
        allow delete: if isSignedIn() &&
                      isValidId(chunkId) &&
                      get(/databases/$(database)/documents/htmlFiles/$(fileId)).data.ownerId == request.auth.uid;
                      
        allow update: if false;
      }
    }
  }
}
